<style>
  :root {
    --black: #000000;
    --white: #FFFFFF;
    --brand-800: #260754;
    --brand-700: #4B0EA3;
    --grad-a: #8729FA;
    --grad-b: #2B0075;
    --gray-10: #F9FAFB;
    --gray-25: #F6F6F7;
    --gray-50: #F1F1F2;
    --gray-100: #DCDCDE;
    --gray-200: #C1C1C4;
    --gray-300: #A6A6AB;
    --gray-700: #3A3A3F;

    --display: 'Poppins', sans-serif;
    --body: 'Figtree', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--body);
    font-weight: 400;
    color: var(--black);
    background: var(--black);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .page-frame {
    max-width: 1440px;
    margin: 0 auto;
    background: var(--white);
    position: relative;
  }

  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ============================ NAV ============================ */
  nav.top {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    background: transparent;
    border-bottom: 1px solid transparent;
    z-index: 100;
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }
  nav.top.scrolled {
    background: rgba(255,255,255,0.78);
    backdrop-filter: saturate(160%) blur(20px);
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    border-bottom-color: var(--gray-50);
  }
  nav.top .container {
    max-width: none;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--white);
    transition: color 0.3s ease;
  }
  nav.top.scrolled .logo { color: var(--black); }
  .logo-img {
    height: 34px;
    width: auto;
    display: block;
  }
  .nav-back {
    font-family: var(--body);
    font-weight: 500;
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 0.25s ease;
  }
  .nav-back:hover { color: var(--white); }
  nav.top.scrolled .nav-back { color: var(--gray-700); }
  nav.top.scrolled .nav-back:hover { color: var(--black); }

  /* ============================ HERO ============================ */
  section.hero {
    background: var(--black);
    color: var(--white);
    padding: 140px 0 80px;
    position: relative;
    overflow: hidden;
    margin-top: -72px; /* tuck under the sticky nav so the background bleeds behind it */
  }
  .hero .container {
    max-width: none;
    padding: 0 32px;
    display: grid;
    gap: 40px;
    position: relative;
    z-index: 2;
  }
  .overline {
    font-family: var(--display);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gray-300);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .overline::before {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--gray-300);
    display: inline-block;
  }
  h1.hero-headline {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 880px;
    color: var(--white);
  }
  h1.hero-headline .accent {
    color: var(--gray-300);
    font-weight: 400;
    font-style: italic;
  }
  .hero-sub {
    font-family: var(--body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--gray-200);
    max-width: 640px;
  }
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 24px;
    padding-top: 36px;
    border-top: 1px solid rgba(255,255,255,0.12);
    max-width: 800px;
  }
  .hero-meta .item .label {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gray-300);
    margin-bottom: 8px;
  }
  .hero-meta .item .value {
    font-family: var(--display);
    font-size: 17px;
    font-weight: 500;
    color: var(--white);
    line-height: 1.4;
  }

  /* ============================ CALENDAR SECTION ============================ */
  section.calendar {
    padding: 80px 0 100px;
    background: var(--white);
  }
  .calendar-wrap {
    max-width: 1000px;
    margin: 0 auto;
    background: var(--white);
    border: 1px solid var(--gray-100);
    box-shadow: 0 24px 60px -28px rgba(0,0,0,0.18), 0 8px 24px -16px rgba(0,0,0,0.08);
    overflow: hidden;
    position: relative;
  }
  .calendar-wrap::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background: linear-gradient(90deg, var(--grad-a) 0%, var(--grad-b) 100%);
    z-index: 1;
  }
  .calendar-iframe {
    width: 100%;
    border: none;
    overflow: hidden;
    display: block;
    min-height: 720px;
  }

  /* ============================ EXPECT SECTION ============================ */
  section.expect {
    padding: 100px 0;
    background: var(--gray-10);
    border-top: 1px solid var(--gray-50);
    border-bottom: 1px solid var(--gray-50);
  }
  .expect .container {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: start;
  }
  .section-label {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gray-300);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .section-label::before {
    content: "";
    width: 32px;
    height: 1px;
    background: currentColor;
    display: inline-block;
  }
  h2 {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(30px, 3.6vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .expect-list {
    display: grid;
    gap: 0;
  }
  .expect-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid var(--gray-100);
    align-items: start;
  }
  .expect-item:last-child { border-bottom: 1px solid var(--gray-100); }
  .expect-num {
    font-family: var(--display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--gray-300);
    padding-top: 4px;
  }
  .expect-content strong {
    font-family: var(--display);
    font-weight: 600;
    font-size: 17px;
    display: block;
    margin-bottom: 6px;
    color: var(--black);
  }
  .expect-content p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--gray-700);
  }

  /* ============================ CONTACT FALLBACK ============================ */
  section.fallback {
    padding: 80px 0;
    background: var(--black);
    color: var(--white);
  }
  .fallback .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .fallback h3 {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin-bottom: 16px;
    color: var(--white);
  }
  .fallback p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--gray-200);
  }
  .contacts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .contacts .label {
    font-family: var(--display);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gray-300);
    margin-bottom: 10px;
    font-weight: 500;
  }
  .contacts a {
    font-family: var(--display);
    font-size: 17px;
    font-weight: 500;
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }
  .contacts a:hover { border-color: var(--white); }

  /* ============================ FOOTER ============================ */
  footer {
    background: var(--black);
    color: var(--gray-300);
    padding: 40px 0;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  footer .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  footer .copy {
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  footer .links {
    display: flex;
    gap: 28px;
  }
  footer .links a {
    font-size: 12px;
    color: var(--gray-300);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  footer .links a:hover { color: var(--white); }

  /* ============================ RESPONSIVE ============================ */
  @media (max-width: 900px) {
    section.hero { padding: 120px 0 56px; }
    section.calendar { padding: 56px 0 72px; }
    section.expect { padding: 72px 0; }
    section.fallback { padding: 60px 0; }
    .expect .container,
    .fallback .container { grid-template-columns: 1fr; gap: 48px; }
    .hero-meta { grid-template-columns: 1fr; gap: 24px; }
    .contacts { grid-template-columns: 1fr; gap: 24px; }
    .container { padding: 0 24px; }
    h1.hero-headline { font-size: 36px; }
    h2 { font-size: 28px; }
    .calendar-iframe { min-height: 800px; }
  }
</style>
